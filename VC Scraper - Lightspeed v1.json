    {
      "parameters": {
        "method": "POST",
        "url": "https://chrome.browserless.io/content",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"url\": \"https://jobs.lsvp.com/companies?stages=Seed+funded&stages=Series+A&stages=Growth&staffCountRanges=1-10&staffCountRanges=10-100&locations=United+States\",\n  \"gotoOptions\": { \"waitUntil\": \"networkidle0\", \"timeout\": 60000 },\n  \"waitForTimeout\": 5000\n}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "fetch-companies",
      "name": "Browserless Lightspeed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 380],
      "credentials": {
        "httpHeaderAuth": {
          "id": "iatzkTu30nb6GVd9",
          "name": "Browserless"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Parse Lightspeed portfolio companies from Consider page HTML\nconst items = $input.all();\nconst html = String(items[0]?.json?.data || items[0]?.json || '');\nconst results = [];\nconst seen = new Set();\nconst today = new Date().toISOString().split('T')[0];\nconst vcName = 'Lightspeed';\n\n// Extract company names from h2.job-boards-company-name elements\nconst namePattern = /class=\"job-boards-company-name\"[^>]*>([^<]+)</gi;\nlet match;\nwhile ((match = namePattern.exec(html)) !== null) {\n  const name = match[1].trim();\n  if (!name || name.length < 2) continue;\n  \n  const key = name.toLowerCase().replace(/[^a-z0-9]/g, '');\n  if (seen.has(key)) continue;\n  seen.add(key);\n  \n  results.push({\n    json: {\n      'Company Name': name,\n      'VC Firm': vcName,\n      'Company Description': name + ' - Lightspeed portfolio company',\n      'Company URL': '',\n      'Stage': '',\n      'Employee Count': '',\n      'Status': 'New',\n      'First Seen Date': today,\n      'Source': 'VC Portfolio'\n    }\n  });\n}\n\nif (results.length === 0) {\n  const hasCompanyItems = html.includes('job-boards-company-item');\n  const hasCompanyNames = html.includes('job-boards-company-name');\n  return [{ json: { _empty: true, _message: 'No companies found', vcName: vcName, htmlLength: html.length, hasCompanyItems: hasCompanyItems, hasCompanyNames: hasCompanyNames } }];\n}\n\nreturn results;"
      },
      "id": "parse-companies",
      "name": "Parse Companies",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 380]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
